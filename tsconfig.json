{
  "extends": "astro/tsconfigs/strictest",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@assets/*": ["src/assets/*"],
      "@layouts/*": ["src/layouts/*"],
      "@components/*": ["src/components/*"],
      "@elements/*": ["src/elements/*"],
      "@styles/*": ["src/styles/*"],
      "@util/*": ["src/util/*"],
    },
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
  }
}